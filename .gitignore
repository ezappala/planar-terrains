!.vscode/unreal-clangd/addMacroCompletions.h
!.vscode/unreal-clangd/.code-workspace.backup

*.tif
*.tiff

# no ai agents in git
[Aa][Gg][Ee][Nn][Tt][Ss].md
.agents
.agent
.codex
.opencode

# Clang
compile_commands.json
.cache

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

